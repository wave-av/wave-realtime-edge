{
  "name": "wave-realtime-edge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run --outdir /tmp/rt-dry",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "egress:kill": "node scripts/kill-egress.mjs on",
    "egress:unkill": "node scripts/kill-egress.mjs off",
    "egress:kill:status": "node scripts/kill-egress.mjs status"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.7",
    "@wave-av/spoke-chassis": "^0.14.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
