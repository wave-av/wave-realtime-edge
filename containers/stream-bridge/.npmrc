; @wave-av/whip-publish is published to GitHub Packages (org-scoped/internal, NOT public npm — see
; wave-foundation/.github/workflows/release-whip-publish.yml). Installing it needs a token with read:packages.
; The token is injected at image-build time as a secret (NEVER committed): the Dockerfile mounts
; GITHUB_TOKEN via --mount=type=secret. Path B self-host exports GITHUB_TOKEN before `npm install`.
;
; min-release-age: refuse to resolve a version published < 7 days ago (supply-chain hardening — a freshly
; published version can be malicious/unstable). The image only builds at ◆ go-live, so our own pinned
; @wave-av/whip-publish@0.2.0 is well past the window by then; this guards against a compromised transitive.
min-release-age = 7
@wave-av:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
